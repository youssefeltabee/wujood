generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            BigInt        @id @default(autoincrement())
  email         String        @unique
  name          String?
  passwordHash  String
  companyName   String?
  companySize   String?
  phone         String?
  role          String        @default("customer")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  audits        Audit[]
  contacts      Contact[]
  conversations Conversation[]
  catalogItems  CatalogItem[]
  reviews       Review[]
  socialAccounts SocialAccount[]
  websites      Website[]
}

model Account {
  id                BigInt   @id @default(autoincrement())
  userId            BigInt
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Subscription {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt
  tier          String   @default("kashif")
  status        String   @default("active")
  priceEgp      Int
  startedAt     DateTime @default(now())
  expiresAt     DateTime?
  canceledAt    DateTime?
  user          User     @relation(fields: [userId], references: [id])
}

model Website {
  id           BigInt        @id @default(autoincrement())
  userId       BigInt
  templateId   BigInt?
  domain       String?
  customDomain String?
  title        String?
  description  String?
  logoUrl      String?
  colors       Json?
  pages        WebsitePage[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
  template     Template?     @relation(fields: [templateId], references: [id])
}

model WebsitePage {
  id        BigInt   @id @default(autoincrement())
  websiteId BigInt
  slug      String
  title     String?
  content   Json?
  order     Int      @default(0)
  website   Website  @relation(fields: [websiteId], references: [id])
}

model Template {
  id          BigInt    @id @default(autoincrement())
  name        String
  category    String    @default("service")
  thumbnail   String?
  isActive    Boolean   @default(true)
  websites    Website[]
  createdAt   DateTime  @default(now())
}

model Audit {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt?
  url         String
  totalScore  Int
  mobileScore Int      @default(0)
  speedScore  Int      @default(0)
  seoScore    Int      @default(0)
  contentScore Int     @default(0)
  socialScore Int      @default(0)
  pricingScore Int     @default(0)
  paymentScore Int     @default(0)
  aiScore     Int      @default(0)
  trustScore  Int      @default(0)
  contactScore Int     @default(0)
  rawData     Json?
  pdfUrl      String?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id])

  @@index([url])
}

model Contact {
  id        BigInt        @id @default(autoincrement())
  userId    BigInt
  name      String?
  phone     String
  email     String?
  notes     String?
  tags      Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id])
  conversations Conversation[]
}

model Conversation {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  contactId BigInt?
  waId      String?
  messages  Json?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  contact   Contact? @relation(fields: [contactId], references: [id])
}

model CatalogItem {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  name        String
  description String?
  priceEgp    Decimal?
  category    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model Review {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  authorName String
  content   String
  rating    Int
  source    String?
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model SocialAccount {
  id        BigInt     @id @default(autoincrement())
  userId    BigInt
  platform  String
  handle    String?
  token     String?
  isActive  Boolean    @default(true)
  posts     SocialPost[]
  user      User       @relation(fields: [userId], references: [id])

  @@unique([userId, platform])
}

model SocialPost {
  id          BigInt        @id @default(autoincrement())
  accountId   BigInt
  content     String
  mediaUrls   Json?
  scheduledAt DateTime?
  postedAt    DateTime?
  status      String        @default("draft")
  analytics   SocialAnalytics?
  account     SocialAccount @relation(fields: [accountId], references: [id])
}

model SocialAnalytics {
  id        BigInt     @id @default(autoincrement())
  postId    BigInt     @unique
  likes     Int        @default(0)
  shares    Int        @default(0)
  comments  Int        @default(0)
  clicks    Int        @default(0)
  reach     Int        @default(0)
  updatedAt DateTime   @updatedAt
  post      SocialPost @relation(fields: [postId], references: [id])
}

model WhatsAppTemplate {
  id        BigInt   @id @default(autoincrement())
  name      String
  category  String   @default("marketing")
  content   String
  language  String   @default("ar")
  status    String   @default("approved")
  createdAt DateTime @default(now())
}
